<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background"
    android:gravity="center_horizontal">

    <!-- Screen Title -->
    <TextView
        android:id="@+id/tv_intro_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_introduce"
        android:textColor="@color/accent_indigo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp" />

    <!-- Name input field -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Wpisz swoje imię"
            android:inputType="textPersonName"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Introduce Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_witaj"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Say Hello"
        android:textSize="18sp"
        android:layout_marginBottom="32dp"
        style="@style/Widget.MaterialComponents.Button" />

    <!-- Output message card-like frame -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:padding="20dp"
        android:layout_marginBottom="24dp">
 
         <TextView
             android:id="@+id/tv_greeting_output"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:text="Przedstaw się."
             android:textColor="@color/text_primary"
             android:textSize="20sp"
             android:layout_gravity="center"
             android:gravity="center" />
     </FrameLayout>

    <!-- Back Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Back"
        android:textSize="18sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>
